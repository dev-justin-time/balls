# =====================================================================
# Puter Game Server — Environment Variables
# =====================================================================
# Copy this file to .env.puter and fill in your values:
#   cp .env.example .env.puter
#
# Generate secrets with:
#   openssl rand -hex 32
# =====================================================================

# ── Domain ──────────────────────────────────────────────────────────
# The main domain where Puter will be accessible
PUTER_DOMAIN=puter.example.com

# ── Database ────────────────────────────────────────────────────────
PUTER_DB_ROOT_PASSWORD=
PUTER_DB_PASSWORD=

# ── Auth Secrets ────────────────────────────────────────────────────
PUTER_JWT_SECRET=
PUTER_SESSION_SECRET=

# ── AWS Credentials (for DynamoDB local) ────────────────────────────
# These can be dummy values for local development
PUTER_AWS_KEY=AKIAIOSFODNN7EXAMPLE
PUTER_AWS_SECRET=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── Going Balls Configuration ───────────────────────────────────────
# These are read by the game client to connect to your Puter instance
# Replace with your actual Puter API domain
PUTER_API_ORIGIN=https://api.your-puter-domain.com
PUTER_APP_ID=going-balls-quad-core
PUTER_ENABLED=true
