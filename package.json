{
  "name": "going-balls-quad-core",
  "version": "2.0.0-alpha",
  "private": true,
  "type": "module",
  "description": "Going Balls — Quad-Core Edition (JS + Rust WASM + Python + Lua)",    "scripts": {
        "predev": "node scripts/vendor-deps.cjs && node scripts/sync-importmaps.cjs",
        "dev": "vite",
        "prestart": "node scripts/vendor-deps.cjs && node scripts/sync-importmaps.cjs",
        "start": "vite",
        "prebuild": "node scripts/vendor-deps.cjs && node scripts/sync-importmaps.cjs",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src/ engine/ main.js",
        "lint:fix": "eslint src/ engine/ main.js --fix",
        "vendor:deps": "node scripts/vendor-deps.cjs",
        "check:vendor": "node scripts/vendor-deps.cjs --check",
        "sync:importmaps": "node scripts/sync-importmaps.cjs",
        "check:importmaps": "node scripts/sync-importmaps.cjs --check",
        "build:wasm": "cd rust_core && wasm-pack build --target web --out-dir pkg",
        "build:wasm:release": "cd rust_core && wasm-pack build --target web --out-dir pkg --release",
        "python:install": "cd python_server && pip install -r requirements.txt",
        "python:dev": "cd python_server && uvicorn main:app --reload --port 8000",
        "python:start": "cd python_server && uvicorn main:app --port 8000",
        "setup:all": "npm install && npm run python:install && npm run build:wasm"
    },
  "dependencies": {
    "@heyputer/puter.js": "^2.5.4",
    "cannon-es": "^0.20.0",
    "nipplejs": "^0.10.1",
    "three": "^0.184.0",
    "wasmoon": "^1.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "vite": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
