# =====================================================================
# Going Balls — Production Environment Variables
# =====================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WARNING: Never commit .env to version control.
# =====================================================================

# ── API Security ────────────────────────────────────────────────────
# Used by: Python FastAPI (server.py) to authenticate client requests
# Generate: openssl rand -hex 32
API_SECRET_KEY=

# ── Level Generation Encryption ─────────────────────────────────────
# Used by: Python FastAPI (server.py) to encrypt/decrypt level payloads
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LEVEL_GEN_FERNET_KEY=

# ── Database ────────────────────────────────────────────────────────
# Used by: PostgreSQL (docker-compose.yml) + Python FastAPI
# Generate: openssl rand -hex 16
DB_PASSWORD=

# ── Optional Overrides (defaults are fine for most deployments) ─────
# CLIENT_ORIGIN=https://play.goingballs.io
# DATABASE_URL=postgresql://app_user:${DB_PASSWORD}@db:5432/going_balls
# REDIS_URL=redis://redis:6379/0
# ENV=production
